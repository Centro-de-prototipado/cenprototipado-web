{
  "name": "cenprototipado",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "turbo typecheck",
    "dev:web": "turbo dev --filter=@cen/web",
    "dev:dashboard": "turbo dev --filter=@cen/dashboard",
    "dev:lms": "turbo dev --filter=@cen/lms"
  },
  "devDependencies": {
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.5.4",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20"
  }
}
